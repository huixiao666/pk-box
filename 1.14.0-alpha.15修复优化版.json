        "detour": "DIRECT"
      },
      {
        "tag": "ggdns",
        "type": "https",
        "server": "dns.google",
        "domain_resolver": "hosts_fix"
      },
      {
        "tag": "doh-ech",
        "type": "https",
        "server": "https://dns.google/dns-query",
        "detour": "PROXY"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      {
        "domain_suffix": ["节点域名"],
        "server": "doh-ech"
      },
      {
        "domain_suffix": [
          "app-measurement.com",
          "hm.baidu.com",
          "firebaselogging.googleapis.com",
