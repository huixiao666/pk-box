        "domain_suffix": [
          "play.google.com",
          "ggpht.com",
          "googleusercontent.com",
          "android.com"
        ],
        "server": "fakeip"
      },
      {
        "domain_suffix": [".cn", ".com.cn"],
        "server": "alidns-dot"
      },
      {
        "action": "evaluate",
        "server": "alidns-quic"
      },
      {
        "match_response": true,
        "rule_set": "cnip",
        "action": "route",
        "server": "local"
      },
      {
        "match_response": true,
        "action": "respond"
      }
    ],
    "final": "alidns-dot",
    "strategy": "prefer_ipv4",
    "reverse_mapping": true,
    "cache_capacity": 65536,
    "optimistic": true
