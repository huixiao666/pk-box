        "server": "local"
      },
      {
        "query_type": ["SVCB", "HTTPS"],
        "action": "reject"
      },
      {
        "query_type": ["PTR"],
        "action": "reject"
      },
      {
        "rule_set": ["proxy", "games", "ai"],
        "query_type": ["A", "AAAA"],
        "server": "fakeip",
        "rewrite_ttl": 300,
        "client_subnet": "119.134.100.0/24" //个人公网IP
      },
      {
        "domain_suffix": ["market.xiaomi.com", "lancache.steamcontent.com"],
        "server": "alidns-quic"
