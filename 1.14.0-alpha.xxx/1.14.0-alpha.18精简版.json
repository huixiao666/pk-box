    },
    {
      "type": "quic",
      "tag": "local",
      "server": "223.5.5.5"          
    },
    {
      "type": "fakeip",
      "tag": "fakeip",
      "inet4_range": "198.18.0.0/15"
    }
  ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "local"
      },
      {
        "clash_mode": "Global",
        "server": "google"
      },
      {
        "query_type": [
          "AAAA"
        ],
        "server": "local"
      },
      {
        "rule_set": "geosite-cn",
        "server": "local"
      },
      {
        "query_type": [
          "A"
        ],
        "server": "fakeip"
      }
    ],
    "strategy": "prefer_ipv4"
